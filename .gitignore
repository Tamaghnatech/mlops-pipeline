# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/

# MLflow
mlruns/

# Reports
reports/*
!reports/drift/drift_history.json
!reports/drift/latest_drift_summary.json
!reports/metrics.json

# VS Code
.vscode/

# DVC internal (keep dvc.lock, ignore cache)
.dvc/cache/
.dvc/tmp/

# Jupyter
.ipynb_checkpoints/
*.ipynb